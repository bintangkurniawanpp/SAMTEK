@page "/admin/mappings"
@using SAMTEK.Application.DTOs
@using SAMTEK.Application.Interfaces
@using SAMTEK.Domain.Entities
@using SAMTEK.Domain.Enums
@using SAMTEK.Infrastructure.Persistence
@using SAMTEK.Web.Services
@using Microsoft.EntityFrameworkCore
@inject IMappingService MappingService
@inject IAuditService AuditService
@inject SamtekDbContext Db
@inject SamtekSession Session
@inject NavigationManager Nav

<PageTitle>User Role Mappings — SAMTEK Admin</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0">User Role Mappings</h2>
            <small class="text-muted">Map IdAMan users to shared ARIS licenses and APPA roles</small>
        </div>
        <button class="btn btn-primary" @onclick="() => showAssignModal = true">
            + Assign Role
        </button>
    </div>

    @if (errorMsg != null)
    {
        <div class="alert alert-danger alert-dismissible">
            @errorMsg
            <button class="btn-close" @onclick="() => errorMsg = null" />
        </div>
    }
    @if (successMsg != null)
    {
        <div class="alert alert-success alert-dismissible">
            @successMsg
            <button class="btn-close" @onclick="() => successMsg = null" />
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Username</th>
                        <th>Display Name</th>
                        <th>Role</th>
                        <th>Last Login</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (mappings == null)
                    {
                        <tr><td colspan="5" class="text-center py-4"><em>Loading…</em></td></tr>
                    }
                    else if (!mappings.Any())
                    {
                        <tr><td colspan="5" class="text-center py-4 text-muted">No mappings yet. Click "+ Assign Role" to add one.</td></tr>
                    }
                    else
                    {
                        @foreach (var m in mappings)
                        {
                            <tr>
                                <td><code>@m.Username</code></td>
                                <td>@m.DisplayName</td>
                                <td>
                                    <span class="badge @(m.AppaRole == AppRole.Designer ? "bg-primary" : "bg-info text-dark") me-1">
                                        @m.AppaRole
                                    </span>
                                    <small class="text-muted">@m.ArisUsername</small>
                                </td>
                                <td>
                                    @if (m.LastLoginAt.HasValue)
                                    {
                                        <span>@m.LastLoginAt.Value.ToLocalTime().ToString("dd MMM yyyy HH:mm")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Belum pernah login</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveAsync(m.Id)">Remove</button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* Assign Role Modal *@
@if (showAssignModal)
{
    <div class="modal d-block" style="background:rgba(0,0,0,.4)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Assign Role</h5>
                    <button class="btn-close" @onclick="CloseModal" />
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">IdAMan Username</label>
                        <input class="form-control" @bind="form.Username" placeholder="e.g. john.doe" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">ARIS Role</label>
                        <select class="form-select" @bind="form.ArisRoleId">
                            <option value="0">-- Select ARIS Role --</option>
                            @foreach (var r in arisRoles)
                            {
                                <option value="@r.Id">@r.RoleCode — @r.ArisUsername (@r.RoleType)</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">APPA Role</label>
                        <select class="form-select" @bind="form.AppaRole">
                            <option value="@AppRole.Viewer">Viewer</option>
                            <option value="@AppRole.Designer">Designer</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Notes (optional)</label>
                        <input class="form-control" @bind="form.Notes" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                    <button class="btn btn-primary" @onclick="AssignAsync" disabled="@saving">
                        @(saving ? "Saving…" : "Assign")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<MappingDto>? mappings;
    private List<ArisRoleDto> arisRoles = [];
    private bool showAssignModal;
    private bool saving;
    private string? errorMsg;
    private string? successMsg;
    private AssignRoleDto form = new();

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAdminAuthenticated)
        {
            Nav.NavigateTo("/admin-login");
            return;
        }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        mappings = await MappingService.GetAllMappingsAsync();
        arisRoles = await Db.ArisRoles
            .Where(r => r.IsActive)
            .Select(r => new ArisRoleDto(r.Id, r.RoleCode, r.ArisUsername, r.RoleType, r.CanPrint, r.CanDownload, r.IsActive))
            .ToListAsync();
    }

    private async Task AssignAsync()
    {
        if (string.IsNullOrWhiteSpace(form.Username) || form.ArisRoleId == 0)
        {
            errorMsg = "Username and ARIS Role are required.";
            return;
        }
        saving = true;
        try
        {
            await MappingService.AssignRoleAsync(form, "admin");
            successMsg = $"Role assigned to {form.Username}.";
            CloseModal();
            await LoadAsync();
        }
        catch (Exception ex) { errorMsg = ex.Message; }
        finally { saving = false; }
    }

    private async Task RemoveAsync(int id)
    {
        try
        {
            await MappingService.RemoveMappingAsync(id, "admin");
            successMsg = "Mapping removed.";
            await LoadAsync();
        }
        catch (Exception ex) { errorMsg = ex.Message; }
    }

    private void CloseModal()
    {
        showAssignModal = false;
        form = new();
        errorMsg = null;
    }
}
